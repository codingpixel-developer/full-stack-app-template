{
  "name": "@codingpixel/create-fullstack-app",
  "version": "0.1.3",
  "description": "CLI to scaffold full-stack projects (Next.js, React, NestJS) with modular web-app, backend, admin, and mobile options",
  "keywords": [
    "cli",
    "scaffold",
    "template",
    "fullstack",
    "nextjs",
    "react",
    "nestjs",
    "vite",
    "monorepo"
  ],
  "author": "codingpixel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codingpixel-developer/full-stack-app-template.git",
    "directory": "cli"
  },
  "bin": {
    "create-fullstack-app": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "tiged": "^2.12.7"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.0",
    "@types/fs-extra": "^11.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
